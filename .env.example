# ─────────────────────────────────────────────────────────
# ProposAI — Environment Variables
# Copy to .env and fill in your values before running.
# ─────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────
# Public URL of the deployed app (used in emails, tracking pixels, etc.)
APP_URL=https://proposai.org

# Random secret for signing session JWTs (generate with: openssl rand -hex 32)
JWT_SECRET=

# ── Database (Postgres) ──────────────────────────────────
# Format: postgresql://user:password@host:5432/dbname
# Railway: set to ${{Postgres.DATABASE_URL}} to reference the Postgres service.
DATABASE_URL=

# ── LLM — Anthropic ──────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Email (SMTP) ──────────────────────────────────────────
# Used for verification emails, proposal emails, follow-ups.
# If unset, emails are logged to the console (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ProposAI <noreply@proposai.org>

# Owner notification email (receives alerts when proposals are viewed, etc.)
OWNER_EMAIL=

# ── File storage (Railway volume in production) ─────────
# Absolute path to the directory where uploaded files (PDFs, logos) live.
# In production this is mounted as a Railway persistent volume.
# Unset locally → defaults to ./uploads under cwd.
STORAGE_DIR=

# ── Google Maps (optional) ───────────────────────────────
# Required only if using Map components or geocoding
GOOGLE_MAPS_API_KEY=

# ── Vite frontend env vars ───────────────────────────────
# These must be prefixed VITE_ to be exposed to the browser build
VITE_APP_ID=proposai
VITE_GOOGLE_MAPS_API_KEY=

# ── Paddle (optional, for billing) ───────────────────────
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=
# VITE_PADDLE_CLIENT_TOKEN=
# VITE_PADDLE_ENVIRONMENT=sandbox
